@model ClothingStoreMVC.WebMVC.ViewModels.CheckoutViewModel
@{
    ViewData["Title"] = "Checkout";
}

<h2 style="font-size:1.4rem; font-weight:900; letter-spacing:0.1em;
    text-transform:uppercase; margin-bottom:2rem; color:#0C0950;">
    Checkout
</h2>

<div style="display:flex; gap:2rem; align-items:flex-start;">

    <!-- Form -->
    <div style="flex:1;">
        <form asp-action="Checkout" method="post">
            @Html.AntiForgeryToken()

            <div style="background:#F9DFDF; border:1px solid #000000;
                border-radius:8px; padding:1.5rem; margin-bottom:1.5rem;">
                <p style="font-size:0.65rem; letter-spacing:0.3em; text-transform:uppercase;
                color:#6b6b8a; margin:0 0 1rem 0;">Delivery Details</p>

                <div style="margin-bottom:1rem;">
                    <label asp-for="DeliveryAddress"
                           style="font-size:0.75rem; letter-spacing:0.1em;
                    text-transform:uppercase; color:#0C0950;
                    display:block; margin-bottom:0.5rem;"></label>
                    <textarea asp-for="DeliveryAddress" rows="3"
                              style="width:100%; padding:0.6rem 0.75rem; border-radius:6px;
                    border:1px solid #2d2d40; background:#fff;
                    color:#0C0950; font-size:0.9rem; resize:vertical;
                    font-family:Georgia,serif; box-sizing:border-box;"></textarea>
                    <span asp-validation-for="DeliveryAddress"
                          style="color:#F57799; font-size:0.75rem;"></span>
                </div>
            </div>

            <button type="submit"
                    style="width:100%; padding:0.85rem; border:none;
                background:linear-gradient(135deg,#8062D6,#E8A9A9);
                color:white; border-radius:4px; font-size:0.85rem;
                letter-spacing:0.15em; text-transform:uppercase; cursor:pointer;">
                Place Order →
            </button>
        </form>
    </div>

    <!-- Summary -->
    <div style="width:280px; flex-shrink:0; position:sticky; top:80px;">
        <div style="background:#F9DFDF; border:1px solid #000000; border-radius:8px; padding:1.5rem;">
            <p style="font-size:0.65rem; letter-spacing:0.3em; text-transform:uppercase;
            color:#6b6b8a; margin:0 0 1rem 0;">Your Items</p>

            @foreach (var item in Model.Items)
            {
                <div style="display:flex; justify-content:space-between;
                    padding:0.5rem 0; border-bottom:1px solid #2d2d40;
                    font-size:0.82rem;">
                    <span style="color:#0C0950;">
                        @item.ProductName <span style="color:#6b6b8a;">× @item.Quantity</span>
                    </span>
                    <span style="color:#8062D6; font-weight:700;">@item.Subtotal ₴</span>
                </div>
            }

            <div style="display:flex; justify-content:space-between;
                padding-top:0.75rem; margin-top:0.25rem;">
                <span style="font-weight:700; color:#0C0950;">Total</span>
                <span style="font-weight:900; font-size:1.1rem; color:#8062D6;">
                    @Model.Total ₴
                </span>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}