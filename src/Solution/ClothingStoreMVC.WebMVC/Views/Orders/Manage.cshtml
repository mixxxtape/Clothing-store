@model IEnumerable<ClothingStoreMVC.WebMVC.ViewModels.AdminOrderViewModel>
@{
    ViewData["Title"] = "Manage Orders";
}

<h2 style="font-size:1.4rem; font-weight:900; letter-spacing:0.1em;
    text-transform:uppercase; margin-bottom:2rem; color:#0C0950;">
    All Orders
</h2>

@if (TempData["Success"] != null)
{
    <div style="background:#0a2d0a; border:1px solid #6bcf6b; color:#6bcf6b;
        padding:0.75rem 1rem; border-radius:6px; margin-bottom:1rem; font-size:0.8rem;">
        @TempData["Success"]
    </div>
}

@if (!Model.Any())
{
    <p style="color:#6b6b8a; text-align:center; padding:3rem;">No orders yet</p>
}
else
{
    @foreach (var order in Model)
    {
        <div style="background:#F9DFDF; border:1px solid #000000; border-radius:8px;
            padding:1.25rem; margin-bottom:1.25rem;">

            <div style="display:flex; justify-content:space-between;
                align-items:flex-start; margin-bottom:1rem; flex-wrap:wrap; gap:0.5rem;">
                <div>
                    <span style="font-size:0.65rem; letter-spacing:0.2em; color:#6b6b8a;
                    text-transform:uppercase;">Order #@order.OrderId</span>
                    <p style="font-size:0.8rem; color:#0C0950; margin:0.2rem 0;">
                        @order.OrderDate.ToString("dd MMM yyyy HH:mm")
                    </p>
                    <p style="font-size:0.75rem; color:#6b6b8a; margin:0;">
                        User: @order.UserName
                    </p>
                    <p style="font-size:0.75rem; color:#6b6b8a; margin:0.2rem 0 0 0;">
                        📍 @order.DeliveryAddress
                    </p>
                </div>
                <span style="padding:0.3rem 0.75rem; border-radius:20px; font-size:0.72rem;
                    letter-spacing:0.1em; text-transform:uppercase; border:1px solid;
                    background:@(order.CurrentStatus == "Pending" ? "#1a1a24" :
                                                                            order.CurrentStatus == "Cancelled" ? "#2d0a0a" :
                                                                            order.CurrentStatus == "Delivered" ? "#0a2d0a" : "#1a1a10");
                    color:@(order.CurrentStatus == "Pending" ? "#8062D6" :
                                                                       order.CurrentStatus == "Cancelled" ? "#F57799" :
                                                                       order.CurrentStatus == "Delivered" ? "#6bcf6b" : "#E8A9A9");">
                    @order.CurrentStatus
                </span>
            </div>

            <div style="margin-bottom:1rem;">
                @foreach (var item in order.Items)
                {
                    <div style="display:flex; justify-content:space-between;
                        font-size:0.8rem; padding:0.3rem 0;
                        border-bottom:1px solid #e0c8c8;">
                        <span style="color:#0C0950;">
                            @item.ProductName
                            <span style="color:#6b6b8a;">
                                · @item.SizeName · ×@item.Quantity
                            </span>
                        </span>
                        <span style="color:#8062D6; font-weight:700;">@item.Subtotal ₴</span>
                    </div>
                }
                <div style="display:flex; justify-content:flex-end; margin-top:0.5rem;">
                    <span style="font-weight:900; color:#0C0950;">Total: @order.Total ₴</span>
                </div>
            </div>

            @if (order.CurrentStatus != "Cancelled" && order.CurrentStatus != "Delivered")
            {
                <div style="display:flex; gap:0.5rem; flex-wrap:wrap; align-items:center;">
                    <span style="font-size:0.7rem; letter-spacing:0.1em;
                        text-transform:uppercase; color:#6b6b8a; margin-right:0.25rem;">
                        Change status:
                    </span>

                    @foreach (var s in new[] { "Processing", "Shipped", "Delivered", "Cancelled" })
                    {
                        if (s != order.CurrentStatus)
                        {
                            <form asp-action="UpdateStatus" method="post" style="display:inline;">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="orderId" value="@order.OrderId" />
                                <input type="hidden" name="status" value="@s" />
                                <button type="submit"
                                        style="padding:0.35rem 0.75rem; border-radius:4px;
                                    font-size:0.72rem; letter-spacing:0.08em;
                                    text-transform:uppercase; cursor:pointer;
                                    border:1px solid @(s == "Cancelled" ? "#F57799" : "#8062D6");
                                    color:@(s == "Cancelled" ? "#F57799" : "#8062D6");
                                    background:transparent; transition:all 0.2s;"
                                        onmouseover="this.style.background=this.style.borderColor;this.style.color='white'"
                                        onmouseout="this.style.background='transparent';this.style.color=this.style.borderColor">
                                    → @s
                                </button>
                            </form>
                        }
                    }
                </div>
            }
        </div>
    }
}