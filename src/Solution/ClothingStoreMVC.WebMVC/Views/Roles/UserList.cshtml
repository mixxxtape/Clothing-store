@model IEnumerable<ClothingStoreMVC.Domain.Entities.UserAggregates.AppUser>
<h2 class="text-2xl font-bold mb-4">Список користувачів</h2>
<table class="table w-full">
    <thead><tr><th>Email</th><th>Дії</th></tr></thead>
    <tbody>
        @foreach (var user in Model)
        {
            <tr>
                <td>@user.Email</td>
                <td>
                    <a class="btn btn-sm btn-primary"
                           asp-action="Edit" asp-route-userId="@user.Id">
                        Права доступу
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>