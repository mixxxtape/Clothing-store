@model ClothingStoreMVC.WebMVC.ViewModels.StyleCreateViewModel
@{
    ViewData["Title"] = "Create Style";
}

<h2 style="font-size:1.2rem; font-weight:900; letter-spacing:0.1em;
    text-transform:uppercase; margin-bottom:1.5rem; color:#0C0950;">
    Add Style
</h2>

<div style="max-width:600px;">
    <form asp-action="Create" method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()

        <div style="background:#F9DFDF; border:1px solid #000; border-radius:8px;
            padding:1.5rem; margin-bottom:1rem;">
            <p style="font-size:0.65rem; letter-spacing:0.3em; text-transform:uppercase;
            color:#6b6b8a; margin:0 0 1rem 0;">Basic Info</p>

            <div style="margin-bottom:1rem;">
                <label asp-for="Name" style="font-size:0.75rem; letter-spacing:0.1em;
                text-transform:uppercase; color:#0C0950; display:block; margin-bottom:0.4rem;"></label>
                <input asp-for="Name" style="width:100%; padding:0.6rem 0.75rem; border-radius:6px;
                border:1px solid #2d2d40; background:#fff; color:#0C0950;
                font-size:0.9rem; box-sizing:border-box;" />
            </div>

            <div>
                <label asp-for="Description" style="font-size:0.75rem; letter-spacing:0.1em;
                text-transform:uppercase; color:#0C0950; display:block; margin-bottom:0.4rem;"></label>
                <textarea asp-for="Description" rows="5"
                          style="width:100%; padding:0.6rem 0.75rem; border-radius:6px;
                border:1px solid #2d2d40; background:#fff; color:#0C0950;
                font-size:0.9rem; font-family:Georgia,serif;
                resize:vertical; box-sizing:border-box;"></textarea>
            </div>
        </div>

        <div style="background:#F9DFDF; border:1px solid #000; border-radius:8px;
            padding:1.5rem; margin-bottom:1rem;">
            <p style="font-size:0.65rem; letter-spacing:0.3em; text-transform:uppercase;
            color:#6b6b8a; margin:0 0 0.5rem 0;">List Image (shown in styles list)</p>
            <input asp-for="ListImageFile" type="file" accept=".jpg,.jpeg,.png,.webp"
                   style="font-size:0.82rem; color:#0C0950; margin-bottom:0.75rem; display:block;" />
            <input asp-for="ListImageUrl" placeholder="or paste URL..."
                   style="width:100%; padding:0.5rem 0.75rem; border-radius:6px;
            border:1px solid #2d2d40; background:#fff; color:#0C0950;
            font-size:0.82rem; box-sizing:border-box;" />
        </div>

        <div style="background:#F9DFDF; border:1px solid #000; border-radius:8px;
            padding:1.5rem; margin-bottom:1rem;">
            <p style="font-size:0.65rem; letter-spacing:0.3em; text-transform:uppercase;
            color:#6b6b8a; margin:0 0 0.5rem 0;">Detail Image (shown on style page)</p>
            <input asp-for="DetailImageFile" type="file" accept=".jpg,.jpeg,.png,.webp"
                   style="font-size:0.82rem; color:#0C0950; margin-bottom:0.75rem; display:block;" />
            <input asp-for="DetailImageUrl" placeholder="or paste URL..."
                   style="width:100%; padding:0.5rem 0.75rem; border-radius:6px;
            border:1px solid #2d2d40; background:#fff; color:#0C0950;
            font-size:0.82rem; box-sizing:border-box;" />
        </div>

        <button type="submit"
                style="padding:0.75rem 2rem; border:none;
            background:linear-gradient(135deg,#8062D6,#E8A9A9);
            color:white; border-radius:4px; font-size:0.8rem;
            letter-spacing:0.15em; text-transform:uppercase; cursor:pointer;">
            Create Style
        </button>
        <a asp-action="Index" style="margin-left:1rem; font-size:0.75rem; color:#6b6b8a;">
            Cancel
        </a>
    </form>
</div>