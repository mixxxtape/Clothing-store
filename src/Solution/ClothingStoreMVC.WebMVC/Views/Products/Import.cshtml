@{
    ViewData["Title"] = "Import Products";
}

<style>
    .btn-back { display:inline-flex; align-items:center; gap:0.4rem; font-size:0.65rem; letter-spacing:0.18em; text-transform:uppercase; color:#6b6b8a; text-decoration:none; margin-bottom:2rem; transition:color 0.2s; }
    .btn-back:hover { color:#8062D6; }
    .form-page-title { font-size:1.4rem; font-weight:900; letter-spacing:0.1em; text-transform:uppercase; color:#0C0950; margin:0 0 1.75rem 0; font-family:Georgia,serif; }

    .import-card {
        background: #F9DFDF;
        border: 1px solid #000;
        border-radius: 8px;
        overflow: hidden;
        max-width: 560px;
    }
    .import-card-header {
        padding: 1rem 1.5rem;
        border-bottom: 2px solid #8062D6;
    }
    .import-card-label {
        font-size: 0.6rem;
        letter-spacing: 0.3em;
        text-transform: uppercase;
        color: #6b6b8a;
        margin: 0;
    }
    .import-card-body { padding: 1.5rem; }

    /* drop zone */
    .drop-zone {
        border: 2px dashed #c4b0c4;
        border-radius: 8px;
        padding: 2rem 1.5rem;
        text-align: center;
        background: rgba(255,255,255,0.5);
        transition: border-color 0.2s, background 0.2s;
        cursor: pointer;
        margin-bottom: 1.25rem;
    }
    .drop-zone:hover, .drop-zone.drag-over {
        border-color: #8062D6;
        background: rgba(128,98,214,0.06);
    }
    .drop-icon { font-size: 2rem; margin-bottom: 0.5rem; color: #8062D6; }
    .drop-label {
        font-size: 0.78rem;
        color: #6b6b8a;
        letter-spacing: 0.08em;
        margin-bottom: 0.4rem;
    }
    .drop-hint { font-size: 0.65rem; letter-spacing:0.1em; text-transform:uppercase; color:#9a8aaa; }
    .file-name-display {
        font-size: 0.78rem;
        color: #0C0950;
        font-weight: 600;
        margin-top: 0.5rem;
        min-height: 1.2em;
    }
    #fileExcel { display: none; }

    .form-actions { display:flex; align-items:center; gap:1rem; }
    .btn-submit { padding:0.7rem 2rem; border:none; background:linear-gradient(135deg,#8062D6,#E8A9A9); color:white; border-radius:4px; font-size:0.78rem; letter-spacing:0.15em; text-transform:uppercase; cursor:pointer; transition:opacity 0.2s; font-family:Georgia,serif; }
    .btn-submit:hover { opacity:0.85; }
    .btn-cancel { font-size:0.72rem; color:#6b6b8a; text-decoration:none; letter-spacing:0.1em; text-transform:uppercase; }
    .btn-cancel:hover { color:#0C0950; }

    .error-block { background:rgba(245,119,153,0.08); border:1px solid #F57799; color:#F57799; padding:0.85rem 1rem; border-radius:6px; margin-bottom:1rem; font-size:0.8rem; }

    /* Template info box */
    .info-box {
        background: rgba(128,98,214,0.08);
        border: 1px solid #8062D6;
        border-radius: 6px;
        padding: 1rem 1.25rem;
        margin-bottom: 1.25rem;
    }
    .info-box-label { font-size:0.6rem; letter-spacing:0.2em; text-transform:uppercase; color:#8062D6; margin:0 0 0.6rem 0; }
    .info-table { width:100%; border-collapse:collapse; font-size:0.78rem; }
    .info-table th { text-align:left; color:#0C0950; font-weight:700; padding:0.3rem 0.5rem; border-bottom:1px solid rgba(128,98,214,0.2); }
    .info-table td { color:#6b6b8a; padding:0.25rem 0.5rem; }
</style>

<a asp-action="Index" class="btn-back">&larr; Back to Products</a>
<h2 class="form-page-title">Import Products</h2>

<div class="import-card">
    <div class="import-card-header">
        <p class="import-card-label">Upload Excel File (.xlsx)</p>
    </div>
    <div class="import-card-body">

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="error-block">
                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <p style="margin:0 0 0.2rem 0;">@error.ErrorMessage</p>
                }
            </div>
        }

        <!-- Expected format info -->
        <div class="info-box">
            <p class="info-box-label">Expected column order</p>
            <table class="info-table">
                <thead>
                    <tr>
                        <th>A</th><th>B</th><th>C</th><th>D</th><th>E</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>Name</td>
                        <td>Description</td>
                        <td>Price</td>
                        <td>Category</td>
                        <td>Style</td>
                    </tr>
                </tbody>
            </table>
            <p style="font-size:0.65rem; color:#9a8aaa; margin:0.6rem 0 0 0; letter-spacing:0.08em;">
                Row 1 is treated as a header and is skipped. Missing categories/styles are created automatically.
            </p>
        </div>

        <form asp-action="Import" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()

            <!-- Drop zone -->
            <div class="drop-zone" id="dropZone" onclick="document.getElementById('fileExcel').click()">
                <div class="drop-icon">📂</div>
                <p class="drop-label">Click to browse or drag & drop your file here</p>
                <p class="drop-hint">.xlsx files only</p>
                <p class="file-name-display" id="fileNameDisplay"></p>
            </div>
            <input type="file" name="fileExcel" id="fileExcel" accept=".xlsx" />

            <div class="form-actions">
                <button type="submit" class="btn-submit">Import</button>
                <a asp-action="Index" class="btn-cancel">Cancel</a>
            </div>
        </form>

    </div>
</div>

<script>
    const input    = document.getElementById('fileExcel');
    const dropZone = document.getElementById('dropZone');
    const display  = document.getElementById('fileNameDisplay');

    input.addEventListener('change', () => {
        display.textContent = input.files[0]?.name ?? '';
    });

    dropZone.addEventListener('dragover', e => {
        e.preventDefault();
        dropZone.classList.add('drag-over');
    });
    dropZone.addEventListener('dragleave', () => dropZone.classList.remove('drag-over'));
    dropZone.addEventListener('drop', e => {
        e.preventDefault();
        dropZone.classList.remove('drag-over');
        const file = e.dataTransfer.files[0];
        if (file) {
            const dt = new DataTransfer();
            dt.items.add(file);
            input.files = dt.files;
            display.textContent = file.name;
        }
    });
</script>
