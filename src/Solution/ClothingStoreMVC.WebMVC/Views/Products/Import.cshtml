@{
    ViewData["Title"] = "Import Products";
}

<style>
    .btn-back { display:inline-flex; align-items:center; gap:0.4rem; font-size:0.65rem; letter-spacing:0.18em; text-transform:uppercase; color:#6b6b8a; text-decoration:none; margin-bottom:2rem; transition:color 0.2s; }
    .btn-back:hover { color:#8062D6; }
    .form-page-title { font-size:1.4rem; font-weight:900; letter-spacing:0.1em; text-transform:uppercase; color:#0C0950; margin:0 0 1.75rem 0; font-family:Georgia,serif; }

    .import-card {
        background: #F9DFDF;
        border: 1px solid #000;
        border-radius: 8px;
        overflow: hidden;
        max-width: 640px;
    }
    .import-card-header {
        padding: 1rem 1.5rem;
        border-bottom: 2px solid #8062D6;
    }
    .import-card-label { font-size:0.6rem; letter-spacing:0.3em; text-transform:uppercase; color:#6b6b8a; margin:0; }
    .import-card-body { padding: 1.5rem; }

    .drop-zone {
        border: 2px dashed #c4b0c4;
        border-radius: 8px;
        padding: 2rem 1.5rem;
        text-align: center;
        background: rgba(255,255,255,0.5);
        transition: border-color 0.2s, background 0.2s;
        cursor: pointer;
        margin-bottom: 1.25rem;
    }
    .drop-zone:hover, .drop-zone.drag-over { border-color: #8062D6; background: rgba(128,98,214,0.06); }
    .drop-icon { font-size:2rem; margin-bottom:0.5rem; color:#8062D6; }
    .drop-label { font-size:0.78rem; color:#6b6b8a; letter-spacing:0.08em; margin-bottom:0.4rem; }
    .drop-hint { font-size:0.65rem; letter-spacing:0.1em; text-transform:uppercase; color:#9a8aaa; }
    .file-name-display { font-size:0.78rem; color:#0C0950; font-weight:600; margin-top:0.5rem; min-height:1.2em; }
    #fileExcel { display:none; }

    .form-actions { display:flex; align-items:center; gap:1rem; }
    .btn-submit { padding:0.7rem 2rem; border:none; background:linear-gradient(135deg,#8062D6,#E8A9A9); color:white; border-radius:4px; font-size:0.78rem; letter-spacing:0.15em; text-transform:uppercase; cursor:pointer; transition:opacity 0.2s; font-family:Georgia,serif; }
    .btn-submit:hover { opacity:0.85; }
    .btn-cancel { font-size:0.72rem; color:#6b6b8a; text-decoration:none; letter-spacing:0.1em; text-transform:uppercase; }
    .btn-cancel:hover { color:#0C0950; }

    .error-block {
        background: rgba(245,119,153,0.08);
        border: 1px solid #F57799;
        border-radius: 6px;
        margin-bottom: 1.25rem;
        overflow: hidden;
    }
    .error-block-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0.7rem 1rem;
        background: rgba(245,119,153,0.15);
        border-bottom: 1px solid #F57799;
    }
    .error-block-title {
        font-size: 0.68rem;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: #F57799;
        font-weight: 700;
        margin: 0;
    }
    .error-count {
        font-size: 0.62rem;
        background: #F57799;
        color: white;
        border-radius: 20px;
        padding: 0.1rem 0.55rem;
        letter-spacing: 0.05em;
    }
    .error-list {
        max-height: 260px;
        overflow-y: auto;
        padding: 0.75rem 1rem;
    }
    .error-item {
        display: flex;
        align-items: flex-start;
        gap: 0.5rem;
        padding: 0.35rem 0;
        border-bottom: 1px solid rgba(245,119,153,0.15);
        font-size: 0.8rem;
        color: #c0304a;
        line-height: 1.4;
    }
    .error-item:last-child { border-bottom: none; }
    .error-bullet { color: #F57799; flex-shrink: 0; font-size: 0.7rem; margin-top: 0.15rem; }

    .info-box {
        background: rgba(128,98,214,0.08);
        border: 1px solid #8062D6;
        border-radius: 6px;
        padding: 1rem 1.25rem;
        margin-bottom: 1.25rem;
    }
    .info-box-label { font-size:0.6rem; letter-spacing:0.2em; text-transform:uppercase; color:#8062D6; margin:0 0 0.6rem 0; }
    .info-table { width:100%; border-collapse:collapse; font-size:0.78rem; }
    .info-table th { text-align:left; color:#0C0950; font-weight:700; padding:0.3rem 0.5rem; border-bottom:1px solid rgba(128,98,214,0.2); }
    .info-table td { color:#6b6b8a; padding:0.25rem 0.5rem; }
    .info-note { font-size:0.65rem; color:#9a8aaa; margin:0.6rem 0 0 0; letter-spacing:0.08em; line-height:1.5; }
</style>

<a asp-action="Index" class="btn-back">&larr; Back to Products</a>
<h2 class="form-page-title">Import Products</h2>

<div class="import-card">
    <div class="import-card-header">
        <p class="import-card-label">Upload Excel File (.xlsx)</p>
    </div>
    <div class="import-card-body">

        @{
            var allErrors = ViewData.ModelState.Values
                .SelectMany(v => v.Errors)
                .Select(e => e.ErrorMessage)
                .ToList();
        }

        @if (allErrors.Any())
        {
            <div class="error-block">
                <div class="error-block-header">
                    <p class="error-block-title">⚠ Validation errors — fix and re-upload</p>
                    <span class="error-count">@allErrors.Count error@(allErrors.Count != 1 ? "s" : "")</span>
                </div>
                <div class="error-list">
                    @foreach (var err in allErrors)
                    {
                        <div class="error-item">
                            <span class="error-bullet">▸</span>
                            <span>@err</span>
                        </div>
                    }
                </div>
            </div>
        }

        <div class="info-box">
            <p class="info-box-label">Expected column order (row 1 = header, skipped)</p>
            <table class="info-table">
                <thead>
                    <tr><th>A</th><th>B</th><th>C</th><th>D</th><th>E</th></tr>
                </thead>
                <tbody>
                    <tr>
                        <td>Name</td>
                        <td>Description</td>
                        <td>Price</td>
                        <td>Category</td>
                        <td>Style</td>
                    </tr>
                </tbody>
            </table>
            <p class="info-note">
                ✦ Category and Style must already exist in the database.<br />
                ✦ Price must be a positive number (max 100 000).<br />
                ✦ Duplicate products (same name + category + style) are skipped silently.
            </p>
        </div>

        <form asp-action="Import" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()

            <div class="drop-zone" id="dropZone"
                 onclick="document.getElementById('fileExcel').click()">
                <div class="drop-icon">📂</div>
                <p class="drop-label">Click to browse or drag & drop your file here</p>
                <p class="drop-hint">.xlsx files only</p>
                <p class="file-name-display" id="fileNameDisplay"></p>
            </div>
            <input type="file" name="fileExcel" id="fileExcel" accept=".xlsx" />

            <div class="form-actions">
                <button type="submit" class="btn-submit">Import</button>
                <a asp-action="Index" class="btn-cancel">Cancel</a>
            </div>
        </form>

    </div>
</div>

<script>
    const input    = document.getElementById('fileExcel');
    const dropZone = document.getElementById('dropZone');
    const display  = document.getElementById('fileNameDisplay');

    input.addEventListener('change', () => {
        display.textContent = input.files[0]?.name ?? '';
    });
    dropZone.addEventListener('dragover', e => {
        e.preventDefault();
        dropZone.classList.add('drag-over');
    });
    dropZone.addEventListener('dragleave', () => dropZone.classList.remove('drag-over'));
    dropZone.addEventListener('drop', e => {
        e.preventDefault();
        dropZone.classList.remove('drag-over');
        const file = e.dataTransfer.files[0];
        if (file) {
            const dt = new DataTransfer();
            dt.items.add(file);
            input.files = dt.files;
            display.textContent = file.name;
        }
    });
</script>
