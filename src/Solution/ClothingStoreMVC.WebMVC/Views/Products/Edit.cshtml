@model ClothingStoreMVC.WebMVC.ViewModels.ProductCreateViewModel
@{ ViewData["Title"] = "Edit Product"; }

<h2 style="font-size:1.2rem; font-weight:900; letter-spacing:0.1em;
    text-transform:uppercase; margin-bottom:1.5rem; color:#0C0950;">
    Edit Product
</h2>

<div style="max-width:600px;">
    <form asp-action="Edit" asp-route-id="@ViewData["ProductId"]" method="post"
          enctype="multipart/form-data">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" style="color:#F57799; font-size:0.8rem; margin-bottom:1rem;"></div>

        <div style="background:#F9DFDF; border:1px solid #000; border-radius:8px;
            padding:1.5rem; margin-bottom:1rem;">
            <p style="font-size:0.65rem; letter-spacing:0.3em; text-transform:uppercase;
                color:#6b6b8a; margin:0 0 1rem 0;">Basic Info</p>

            <div style="margin-bottom:1rem;">
                <label asp-for="Name" style="font-size:0.75rem; letter-spacing:0.1em;
                    text-transform:uppercase; color:#0C0950; display:block; margin-bottom:0.4rem;"></label>
                <input asp-for="Name" style="padding:0.6rem 0.75rem; border-radius:6px;
                    border:1px solid #2d2d40; background:#fff; color:#0C0950;
                    font-size:0.9rem; width:100%; box-sizing:border-box;" />
                <span asp-validation-for="Name" style="color:#F57799; font-size:0.75rem;"></span>
            </div>
            <div style="margin-bottom:1rem;">
                <label asp-for="Description" style="font-size:0.75rem; letter-spacing:0.1em;
                    text-transform:uppercase; color:#0C0950; display:block; margin-bottom:0.4rem;"></label>
                <input asp-for="Description" style="padding:0.6rem 0.75rem; border-radius:6px;
                    border:1px solid #2d2d40; background:#fff; color:#0C0950;
                    font-size:0.9rem; width:100%; box-sizing:border-box;" />
                <span asp-validation-for="Description" style="color:#F57799; font-size:0.75rem;"></span>
            </div>
            <div style="margin-bottom:1rem;">
                <label asp-for="Price" style="font-size:0.75rem; letter-spacing:0.1em;
                    text-transform:uppercase; color:#0C0950; display:block; margin-bottom:0.4rem;"></label>
                <input asp-for="Price" style="padding:0.6rem 0.75rem; border-radius:6px;
                    border:1px solid #2d2d40; background:#fff; color:#0C0950;
                    font-size:0.9rem; width:100%; box-sizing:border-box;" />
                <span asp-validation-for="Price" style="color:#F57799; font-size:0.75rem;"></span>
            </div>
            <div style="margin-bottom:1rem;">
                <label style="font-size:0.75rem; letter-spacing:0.1em; text-transform:uppercase;
                color:#0C0950; display:block; margin-bottom:0.75rem;">Product Image</label>

                @if (!string.IsNullOrEmpty(Model.ImagePath))
                {
                    <div style="margin-bottom:1rem;">
                        <img src="@Model.ImagePath"
                             style="width:100px; height:100px; object-fit:cover;
                        border-radius:6px; border:1px solid #2d2d40;" />
                        <p style="font-size:0.7rem; color:#6b6b8a; margin:0.4rem 0 0 0;">
                            Current — upload file or paste URL to replace
                        </p>
                    </div>
                }

                <div style="margin-bottom:0.75rem;">
                    <label style="font-size:0.7rem; letter-spacing:0.1em; text-transform:uppercase;
                    color:#6b6b8a; display:block; margin-bottom:0.4rem;">From file</label>
                    <input asp-for="ImageFile" type="file" accept=".jpg,.jpeg,.png,.webp"
                           style="font-size:0.82rem; color:#0C0950;" />
                </div>

                <div style="display:flex; align-items:center; gap:0.75rem; margin-bottom:0.75rem;">
                    <div style="flex:1; height:1px; background:#e0c8c8;"></div>
                    <span style="font-size:0.65rem; color:#6b6b8a; letter-spacing:0.1em; text-transform:uppercase;">or</span>
                    <div style="flex:1; height:1px; background:#e0c8c8;"></div>
                </div>

                <div>
                    <label style="font-size:0.7rem; letter-spacing:0.1em; text-transform:uppercase;
                    color:#6b6b8a; display:block; margin-bottom:0.4rem;">From URL</label>
                    <input asp-for="ImageUrl"
                           placeholder="https://example.com/image.jpg"
                           style="width:100%; padding:0.6rem 0.75rem; border-radius:6px;
                    border:1px solid #2d2d40; background:#fff; color:#0C0950;
                    font-size:0.85rem; box-sizing:border-box;" />
                </div>
            </div>

            <div style="display:grid; grid-template-columns:1fr 1fr; gap:1rem;">
                <div>
                    <label asp-for="StyleId" style="font-size:0.75rem; letter-spacing:0.1em;
                        text-transform:uppercase; color:#0C0950; display:block; margin-bottom:0.4rem;">Style</label>
                    <select asp-for="StyleId" asp-items="ViewBag.StyleId"
                            style="padding:0.6rem 0.75rem; border-radius:6px; border:1px solid #2d2d40;
                            background:#fff; color:#0C0950; font-size:0.9rem; width:100%;"></select>
                </div>
                <div>
                    <label asp-for="CategoryId" style="font-size:0.75rem; letter-spacing:0.1em;
                        text-transform:uppercase; color:#0C0950; display:block; margin-bottom:0.4rem;">Category</label>
                    <select asp-for="CategoryId" asp-items="ViewBag.CategoryId"
                            style="padding:0.6rem 0.75rem; border-radius:6px; border:1px solid #2d2d40;
                            background:#fff; color:#0C0950; font-size:0.9rem; width:100%;"></select>
                </div>
            </div>

            <div style="margin-top:1rem;">
                <label style="display:flex; align-items:center; gap:0.5rem;
                    font-size:0.8rem; color:#0C0950; cursor:pointer;">
                    <input asp-for="IsDeleted" type="checkbox" />
                    Mark as deleted
                </label>
            </div>
        </div>

        <div style="background:#F9DFDF; border:1px solid #000; border-radius:8px;
            padding:1.5rem; margin-bottom:1rem;">
            <p style="font-size:0.65rem; letter-spacing:0.3em; text-transform:uppercase;
                color:#6b6b8a; margin:0 0 1rem 0;">Sizes & Stock</p>

            @for (int i = 0; i < Model.Sizes.Count; i++)
            {
                <input type="hidden" asp-for="Sizes[i].SizeId" />
                <input type="hidden" asp-for="Sizes[i].SizeName" />

                <div style="display:flex; align-items:center; gap:1rem;
                    padding:0.6rem 0; border-bottom:1px solid #e0c8c8;">
                    <label style="display:flex; align-items:center; gap:0.5rem;
                        min-width:120px; font-size:0.85rem; color:#0C0950; cursor:pointer;">
                        <input asp-for="Sizes[i].IsSelected" type="checkbox"
                               onchange="toggleQty(this)" />
                        @Model.Sizes[i].SizeName
                    </label>
                    <input asp-for="Sizes[i].Quantity" type="number" min="0"
                           id="qty_@i"
                           style="width:80px; padding:0.4rem 0.5rem; border-radius:4px;
                    border:1px solid #2d2d40; font-size:0.85rem; text-align:center;
                    background:@(Model.Sizes[i].IsSelected ? "#fff" : "#e8e8e8");
                    color:@(Model.Sizes[i].IsSelected ? "#0C0950" : "#aaa");
                    pointer-events:@(Model.Sizes[i].IsSelected ? "auto" : "none");" />
                    <span style="font-size:0.75rem; color:#6b6b8a;">pcs</span>
                </div>
            }
        </div>

        <button type="submit"
                style="padding:0.75rem 2rem; border:none;
                background:linear-gradient(135deg,#8062D6,#E8A9A9);
                color:white; border-radius:4px; font-size:0.8rem;
                letter-spacing:0.15em; text-transform:uppercase; cursor:pointer;">
            Save Changes
        </button>
        <a asp-action="Index" style="margin-left:1rem; font-size:0.75rem; color:#6b6b8a;">
            Cancel
        </a>
    </form>
</div>

<script>
    function toggleQty(checkbox) {
        var row = checkbox.closest('div');
        var qty = row.querySelector('input[type="number"]');
        if (checkbox.checked) {
            qty.style.background = '#fff';
            qty.style.color = '#0C0950';
            qty.style.pointerEvents = 'auto';
            qty.focus();
        } else {
            qty.style.background = '#e8e8e8';
            qty.style.color = '#aaa';
            qty.style.pointerEvents = 'none';
            qty.value = 0;
        }
    }
</script>