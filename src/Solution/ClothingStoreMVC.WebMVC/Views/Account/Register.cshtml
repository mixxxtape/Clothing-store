@model ClothingStoreMVC.WebMVC.ViewModels.RegisterViewModel
<h2 class="text-2xl font-bold mb-4">Реєстрація</h2>
<form method="post" asp-controller="Account" asp-action="Register" class="max-w-md">
    <div asp-validation-summary="ModelOnly" class="text-error mb-2"></div>
    <div class="mb-3">
        <label asp-for="Email" class="label"></label>
        <input asp-for="Email" class="input w-full" />
        <span asp-validation-for="Email" class="text-error text-sm"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Password" class="label"></label>
        <input asp-for="Password" class="input w-full" />
        <span asp-validation-for="Password" class="text-error text-sm"></span>
    </div>
    <div class="mb-3">
        <label asp-for="PasswordConfirm" class="label"></label>
        <input asp-for="PasswordConfirm" class="input w-full" />
        <span asp-validation-for="PasswordConfirm" class="text-error text-sm"></span>
    </div>
    <button type="submit" class="btn btn-primary">Зареєструватися</button>
    <a asp-action="Login" class="btn btn-ghost">Вже є акаунт?</a>
</form>