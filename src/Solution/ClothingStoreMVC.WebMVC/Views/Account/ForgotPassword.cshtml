@model ClothingStoreMVC.WebMVC.ViewModels.ForgotPasswordViewModel
@{
    ViewData["Title"] = "Forgot Password";
}

<div style="max-width:480px; margin:3rem auto;">
    <div class="dark-card" style="padding:2.5rem;">
        <h2 style="color:#e2e2f0; font-size:1.1rem; letter-spacing:0.2em;
            text-transform:uppercase; margin:0 0 1rem 0; text-align:center;">
            Forgot Password
        </h2>
        <p style="color:#6b6b8a; font-size:0.8rem; text-align:center;
            margin:0 0 2rem 0; line-height:1.6;">
            Enter your email and we'll send you a reset link
        </p>

        <form asp-action="ForgotPassword" method="post">
            @Html.AntiForgeryToken()
            <div style="margin-bottom:1.5rem;">
                <label asp-for="Email"
                       style="display:block; font-size:0.7rem; letter-spacing:0.12em;
                text-transform:uppercase; color:#6b6b8a; margin-bottom:0.4rem;"></label>
                <input asp-for="Email" type="email"
                       style="width:100%; box-sizing:border-box; background:#0d0d14;
                border:1px solid #2d2d40; border-radius:4px; padding:0.6rem 0.9rem;
                color:#e2e2f0; font-size:0.85rem; outline:none;" />
                <span asp-validation-for="Email" style="color:#F57799; font-size:0.75rem;"></span>
            </div>

            <button type="submit"
                    style="width:100%; padding:0.7rem; border:none; cursor:pointer;
                border-radius:4px; font-size:0.75rem; letter-spacing:0.15em;
                text-transform:uppercase;
                background:linear-gradient(135deg,#6367FF,#FE81D4); color:white;">
                Send Reset Link
            </button>

            <p style="text-align:center; margin-top:1.2rem; font-size:0.75rem; color:#6b6b8a;">
                <a asp-action="Login" style="color:#FE81D4; text-decoration:none;">Back to Sign In</a>
            </p>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}