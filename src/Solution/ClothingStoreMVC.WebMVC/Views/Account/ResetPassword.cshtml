@model ClothingStoreMVC.WebMVC.ViewModels.ResetPasswordViewModel
@{
    ViewData["Title"] = "Reset Password";
}

<div style="max-width:480px; margin:3rem auto;">
    <div class="dark-card" style="padding:2.5rem;">
        <h2 style="color:#e2e2f0; font-size:1.1rem; letter-spacing:0.2em;
            text-transform:uppercase; margin:0 0 2rem 0; text-align:center;">
            Reset Password
        </h2>

        <form asp-action="ResetPassword" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Token" />
            <input type="hidden" asp-for="Email" />

            <div asp-validation-summary="ModelOnly"
                 style="color:#F57799; font-size:0.8rem; margin-bottom:1rem;"></div>

            @foreach (var (prop, label) in new[] {
                ("NewPassword", "New Password"),
                ("ConfirmPassword", "Confirm Password")
            })
            {
                <div style="margin-bottom:1.2rem;">
                    <label style="display:block; font-size:0.7rem; letter-spacing:0.12em;
                        text-transform:uppercase; color:#6b6b8a; margin-bottom:0.4rem;">
                        @label
                    </label>
                    <input name="@prop" type="password"
                           style="width:100%; box-sizing:border-box; background:#0d0d14;
                    border:1px solid #2d2d40; border-radius:4px;
                    padding:0.6rem 0.9rem; color:#e2e2f0; font-size:0.85rem; outline:none;" />
                </div>
            }

            <button type="submit"
                    style="width:100%; padding:0.7rem; border:none; cursor:pointer;
                border-radius:4px; font-size:0.75rem; letter-spacing:0.15em;
                text-transform:uppercase;
                background:linear-gradient(135deg,#6367FF,#FE81D4); color:white;">
                Reset Password
            </button>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}