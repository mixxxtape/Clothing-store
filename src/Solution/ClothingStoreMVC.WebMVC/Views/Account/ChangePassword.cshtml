@model ClothingStoreMVC.WebMVC.ViewModels.ChangePasswordViewModel
@{ ViewData["Title"] = "Change Password"; }

<style>
    .field-input {
        width: 100%; box-sizing: border-box;
        background: #fff; border: 1px solid #2d2d40;
        border-radius: 6px; padding: 0.6rem 0.75rem;
        color: #0C0950; font-size: 0.9rem; outline: none;
        font-family: Georgia, serif; transition: border-color 0.2s;
    }
    .field-input:focus { border-color: #8062D6; }
</style>

<div style="max-width:480px;">
    <a asp-action="Profile"
       style="font-size:0.65rem; letter-spacing:0.18em; text-transform:uppercase;
       color:#6b6b8a; text-decoration:none; display:inline-block; margin-bottom:1.5rem;">
        ← Back to Profile
    </a>

    <h2 style="font-size:1.2rem; font-weight:900; letter-spacing:0.1em;
        text-transform:uppercase; margin-bottom:1.5rem; color:#0C0950;">
        Change Password
    </h2>

    @if (TempData["Error"] != null)
    {
        <div style="background:#2d0a0a; border:1px solid #F57799; color:#F57799;
            padding:0.75rem 1rem; border-radius:6px; margin-bottom:1rem; font-size:0.8rem;">
            @TempData["Error"]
        </div>
    }

    <form asp-action="ChangePassword" method="post">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly"
             style="color:#F57799; font-size:0.8rem; margin-bottom:1rem;"></div>

        <div style="background:#F9DFDF; border:1px solid #000; border-radius:8px;
            padding:1.5rem; margin-bottom:1rem;">

            @foreach (var (prop, label) in new[] {
                ("CurrentPassword", "Current Password"),
                ("NewPassword", "New Password"),
                ("ConfirmNewPassword", "Confirm New Password")
            })
            {
                <div style="margin-bottom:1rem;">
                    <label style="font-size:0.72rem; letter-spacing:0.1em; text-transform:uppercase;
                        color:#0C0950; display:block; margin-bottom:0.4rem;">@label</label>
                    <input name="@prop" type="password" class="field-input" />
                </div>
            }
        </div>

        <button type="submit"
                style="padding:0.75rem 2rem; border:none;
                background:linear-gradient(135deg,#8062D6,#E8A9A9);
                color:white; border-radius:4px; font-size:0.8rem;
                letter-spacing:0.15em; text-transform:uppercase; cursor:pointer;">
            Change Password
        </button>
    </form>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}