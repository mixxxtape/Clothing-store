@model ClothingStoreMVC.Domain.Entities.QuizAggregates.Answer
<h1>Edit answer</h1>
<div class="row"><div class="col-md-5">
    <form asp-action="EditAnswer" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" name="id" value="@Model.Id" />

        <div class="form-group">
            <label>Answer text</label>
            <input name="text" value="@Model.Text" class="form-control" required />
        </div>

            <div class="form-group mt-2">
                <label>Styles</label>
                <div>
                    @foreach (var style in ViewBag.Styles)
                    {
                        var selected = (List<int>)ViewBag.SelectedStyles;
                        <div>
                            <label>
                                <input type="checkbox" name="selectedStyles" value="@style.Id"
                                @(selected.Contains(style.Id) ? "checked" : "") />
                                @style.Name
                            </label>
                        </div>
                    }
                </div>
            </div>

        <div class="form-group mt-2">
            <input type="submit" value="Save" class="btn btn-primary" />
        </div>
    </form>
</div></div>
<a asp-action="Manage">Back</a>