@model ClothingStoreMVC.Domain.Entities.QuizAggregates.Question
<h1>Add question</h1>
<div class="row">
    <div class="col-md-5">
        <form asp-action="CreateQuestion" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="quizId" value="@ViewBag.QuizId" />
            <div class="form-group">
                <label>Question text</label>
                <input name="text" class="form-control" required />
            </div>
            <div class="form-group mt-2">
                <input type="submit" value="Add" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>
<a asp-action="Manage">Back</a>
@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

}