<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Ravel</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/css/app.min.css" asp-append-version="true" />
    <style>
        body { background: #EEEEEE; color: #000000; font-family: Georgia, serif; margin: 0; }

        .nav-bar {
            background: #000000;
            border-bottom: 1px solid #1a1a1a;
            position: sticky;
            top: 0;
            z-index: 50;
        }
        .nav-inner {
            max-width: 1280px;
            margin: 0 auto;
            padding: 0 1.5rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
            height: 64px;
            gap: 1rem;
        }
        .nav-logo {
            font-size: 1.3rem;
            font-weight: 900;
            letter-spacing: 0.2em;
            text-transform: uppercase;
            text-decoration: none;
            background: linear-gradient(135deg, #6367FF, #FE81D4);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            flex-shrink: 0;
        }
        .nav-links {
            display: flex;
            align-items: center;
            gap: 0.1rem;
            flex: 1;
            justify-content: center;
        }
        .nav-link {
            color: #eeeeee;
            font-size: 0.75rem;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            padding: 0.4rem 0.65rem;
            border-radius: 4px;
            text-decoration: none;
            transition: all 0.2s;
        }
        .nav-link:hover { color: #eeeeee; background: #1a1a24; }
        .nav-icons {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            flex-shrink: 0;
        }
        .nav-icon-btn {
            width: 38px;
            height: 38px;
            border-radius: 6px;
            background: transparent;
            color: #9999bb;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            text-decoration: none;
            transition: all 0.2s;
            position: relative;
            font-size: 1rem;
            border: none;
        }
        .nav-icon-btn:hover { border-color: #F57799; color: #e2e2f0; background: #1a1a24; }
        .btn-ghost {
            padding: 0.4rem 1rem;
            border-radius: 4px;
            font-size: 0.72rem;
            letter-spacing: 0.1em;
            text-transform: uppercase;
            text-decoration: none;
            transition: all 0.2s;
            border: 1px solid #2d2d40;
            color: #9999bb;
            background: transparent;
        }
        .btn-ghost:hover { border-color: #F57799; color: #e2e2f0; }
        .btn-primary {
            padding: 0.4rem 1rem;
            border-radius: 4px;
            font-size: 0.72rem;
            letter-spacing: 0.1em;
            text-transform: uppercase;
            text-decoration: none;
            transition: all 0.2s;
            background: linear-gradient(135deg, #F57799, #EEEEEE);
            color: white;
            border: none;
            cursor: pointer;
        }
        .btn-primary:hover { opacity: 0.85; }
        .btn-danger {
            padding: 0.4rem 1rem;
            border-radius: 4px;
            font-size: 0.72rem;
            letter-spacing: 0.1em;
            text-transform: uppercase;
            transition: all 0.2s;
            border: 1px solid #2d2d40;
            color: #9999bb;
            background: transparent;
            cursor: pointer;
        }
        .btn-danger:hover { border-color: #F57799; color: #F57799; }
        .nav-divider { width: 1px; height: 20px; background: #2d2d40; margin: 0 0.25rem; }
        .dark-card {
            background: #13131a;
            border: 1px solid #2d2d40;
            border-radius: 8px;
            transition: border-color 0.2s, transform 0.2s;
        }
        .dark-card:hover { border-color: #E491C9; transform: translateY(-2px); }
        footer {
            background: #0d0d14;
            border-top: 1px solid #2d2d40;
            color: #6b6b8a;
            font-size: 0.75rem;
            letter-spacing: 0.12em;
            text-align: center;
            padding: 2rem 1.5rem;
            margin-top: 4rem;
        }
        ::-webkit-scrollbar { width: 5px; }
        ::-webkit-scrollbar-track { background: #0a0a0f; }
        ::-webkit-scrollbar-thumb { background: #2d2d40; border-radius: 3px; }
        ::-webkit-scrollbar-thumb:hover { background: #4D2FB2; }

        .admin-wrap {
            position: relative;
        }
        .admin-toggle {
            color: #eeeeee;
            font-size: 0.75rem;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            padding: 0.4rem 0.65rem;
            border-radius: 4px;
            cursor: pointer;
            transition: all 0.2s;
            user-select: none;
        }
        .admin-toggle:hover { background: #1a1a24; }
        .admin-menu {
            display: none;
            position: absolute;
            top: calc(100% + 8px);
            left: 0;
            background: #13131a;
            border: 1px solid #2d2d40;
            border-radius: 8px;
            min-width: 160px;
            padding: 0.5rem;
            z-index: 999;
        }
        .admin-menu.is-open { display: block; }
        .dropdown-item {
            display: block;
            padding: 0.5rem 0.75rem;
            font-size: 0.75rem;
            letter-spacing: 0.1em;
            text-transform: uppercase;
            color: #9999bb;
            text-decoration: none;
            border-radius: 4px;
            transition: all 0.2s;
        }
        .dropdown-item:hover { background: #1a1a24; color: #e2e2f0; }

    </style>
</head>
<body>

<header class="nav-bar">
    <div class="nav-inner">

        <a asp-controller="Home" asp-action="Index" class="nav-logo">RAVEL</a>

       <nav class="nav-links">
            <a asp-controller="Home" asp-action="Index" class="nav-link">Main</a>
            <a asp-controller="Catalog" asp-action="Index" class="nav-link">Catalogue</a>

            @if (!User.IsInRole("admin"))
            {
                <a asp-controller="Styles" asp-action="Index" class="nav-link">Styles</a>
            }

            @if (User.Identity.IsAuthenticated && User.IsInRole("user"))
            {
                <a asp-controller="Quiz" asp-action="Index" class="nav-link">Style Quiz</a>
            }

            @if (User.IsInRole("admin"))
            {
                <div class="admin-wrap" id="adminWrap">
                    <span class="admin-toggle" id="adminToggle">Admin ▾</span>
                    <div class="admin-menu" id="adminMenu">
                        <a asp-controller="Products" asp-action="Index" class="dropdown-item">Products</a>
                        <a asp-controller="Categories" asp-action="Index" class="dropdown-item">Categories</a>
                        <a asp-controller="Sizes" asp-action="Index" class="dropdown-item">Sizes</a>
                        <a asp-controller="Styles" asp-action="Index" class="dropdown-item">Styles</a>
                        <a asp-controller="Quiz" asp-action="Manage" class="dropdown-item">Quiz</a>
                        <a asp-controller="Orders" asp-action="Manage" class="dropdown-item">Orders</a>
                        <a asp-controller="Analytics" asp-action="Index" class="dropdown-item">Analytics</a>
                        <a asp-controller="Users" asp-action="Index" class="dropdown-item">Users</a>
                    </div>
        </div>
    }
</nav>

        <div class="nav-icons">
            @if (User.Identity.IsAuthenticated)
            {
                @if (!User.IsInRole("admin"))
                {
                    <a asp-controller="Wishlists" asp-action="Index" class="nav-icon-btn" title="Wishlist">
                        <img src="@Url.Content("~/images/wishlist.jpg")" />
                    </a>
                    <a asp-controller="Carts" asp-action="Index" class="nav-icon-btn" title="Cart">
                        <img src="@Url.Content("~/images/cart.jpg")" />
                    </a>
                    <a asp-controller="Orders" asp-action="Index" class="nav-icon-btn" title="My Orders">
                        <img src="@Url.Content("~/images/orders.png")" />
                    </a>
                }
                <a asp-controller="Account" asp-action="Profile"
                   class="nav-icon-btn" title="My Profile">
                    <img src="@Url.Content("~/images/account.jpg")" />
                </a>
            }
            else
            {
                <a asp-controller="Account" asp-action="Login" class="btn-ghost">Sign In</a>
                <a asp-controller="Account" asp-action="Register" class="btn-primary">Join</a>
            }
        </div>

    </div>
</header>

<main style="width:100%; padding:2rem 3rem;">
    @RenderBody()
</main>

<footer>
    <p style="text-transform:uppercase;">Ravel</p>
    <p style="margin-top:0.4rem; opacity:0.5;">Lets go put on a mask</p>
</footer>
@RenderSection("Scripts", required: false)
<script>
    document.addEventListener("DOMContentLoaded", function () {
        const toggle = document.getElementById("adminToggle");
        const menu = document.getElementById("adminMenu");

        if (toggle && menu) {
            toggle.addEventListener("click", function () {
                menu.classList.toggle("is-open");
            });

            document.addEventListener("click", function (e) {
                if (!document.getElementById("adminWrap").contains(e.target)) {
                    menu.classList.remove("is-open");
                }
            });
        }
    });
</script>
</body>
</html>