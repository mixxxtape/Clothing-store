<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ClothingStoreMVC.WebMVC</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/css/app.min.css" asp-append-version="true" />
</head>
<body>
    <header>
        <div class="navbar bg-base-100 shadow-md">
            <div class="flex-1">
                <a class="btn btn-ghost text-xl" asp-controller="Home" asp-action="Index">
                    ClothingStore
                </a>
            </div>
            <div class="flex-none">
                <ul class="menu menu-horizontal px-1">
                    <li><a asp-controller="Home" asp-action="Index">Головна</a></li>
                    <li><a asp-controller="Products" asp-action="Index">Товари</a></li>
                    <li><a asp-controller="Categories" asp-action="Index">Категорії</a></li>
                    <li><a asp-controller="Styles" asp-action="Index">Стилі</a></li>
                    <li><a asp-controller="Sizes" asp-action="Index">Розміри</a></li>
                    <li><a asp-controller="Reviews" asp-action="Index">Відгуки</a></li>
                    <li><a asp-controller="Quizs" asp-action="Index">Квіз</a></li>
                </ul>
            </div>
            <div class="flex items-center gap-2">
                @if (User.Identity.IsAuthenticated)
                {
                    <span class="text-sm">@User.Identity.Name</span>
                    @if (User.IsInRole("admin"))
                    {
                        <a asp-controller="Roles" asp-action="UserList" class="btn btn-sm">Адмін</a>
                    }
                    <form method="post" asp-controller="Account" asp-action="Logout">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-sm btn-error">Вихід</button>
                    </form>
                }
                else
                {
                    <a asp-controller="Account" asp-action="Login" class="btn btn-sm">Вхід</a>
                    <a asp-controller="Account" asp-action="Register" class="btn btn-sm btn-primary">Реєстрація</a>
                }
            </div>
        </div>
    </header>
    <div class="max-w-7xl mx-auto px-4">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-t mt-10 py-4 text-center text-sm text-gray-500">
        &copy; 2026 - ClothingStoreMVC.WebMVC
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>