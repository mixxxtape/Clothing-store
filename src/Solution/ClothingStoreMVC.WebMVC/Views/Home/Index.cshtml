@model IEnumerable<ClothingStoreMVC.Domain.Entities.ProductAggregates.Product>
@{ ViewData["Title"] = "Home"; }

<style>
    .home-wrap {
        display: flex;
        gap: 0;
        min-height: calc(100vh - 64px - 60px);
        margin: -2rem -1.5rem;
    }
    .home-sidebar {
        width: 33.333%;
        flex-shrink: 0;
        background: #F9DFDF;
        border-right: 1px solid #000;
        display: flex;
        flex-direction: column;
    }
    .sidebar-header {
        padding: 1.5rem;
        border-bottom: 2px solid #8062D6;
    }
    .sidebar-eyebrow {
        font-size: 0.6rem;
        letter-spacing: 0.3em;
        text-transform: uppercase;
        color: #6b6b8a;
        margin: 0;
    }
    .sidebar-items {
        flex: 1;
        overflow-y: auto;
        display: flex;
        flex-direction: column;
    }
    .sidebar-item {
        display: flex;
        flex-direction: column;
        text-decoration: none;
        transition: background 0.2s;
        flex: 1;
        min-height: 0;
        position: relative;
        overflow: hidden;
    }
    .sidebar-item:hover { background: rgba(255,255,255,0.3); }
    .sidebar-thumb {
        width: 100%;
        flex: 1;
        min-height: 120px;
        overflow: hidden;
        background: #e8d5d5;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .sidebar-thumb img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }
    .sidebar-item-info {
        padding: 0.75rem 1rem;
        border-bottom: 1px solid rgba(0,0,0,0.08);
        background: #F9DFDF;
    }
    .sidebar-thumb-icon {
        font-size: 1.5rem;
        opacity: 0.2;
        color: #8062D6;
    }
    .sidebar-item-name {
        font-size: 0.82rem;
        font-weight: 700;
        color: #0C0950;
        margin: 0 0 0.2rem 0;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }
    .sidebar-item-style {
        font-size: 0.7rem;
        color: #6b6b8a;
        margin: 0 0 0.2rem 0;
    }
    .sidebar-item-price {
        font-size: 0.85rem;
        font-weight: 700;
        color: #8062D6;
        margin: 0;
    }
    .sidebar-footer {
        padding: 1rem 1.5rem;
        border-top: 1px solid rgba(0,0,0,0.08);
    }
    .home-content {
        flex: 1;
        padding: 3rem 3rem;
        display: flex;
        flex-direction: column;
        justify-content: center;
    }
</style>

<div class="home-wrap">

    <div class="home-sidebar">
        <div class="sidebar-header">
            <p class="sidebar-eyebrow">New Arrivals</p>
        </div>

        <div class="sidebar-items">
            @if (!Model.Any())
            {
                <div style="padding:2rem; text-align:center; color:#6b6b8a; font-size:0.8rem;">
                    No products yet
                </div>
            }
            @foreach (var item in Model)
            {
                <a asp-controller="Catalog" asp-action="Details"
                   asp-route-id="@item.Id" class="sidebar-item">
                    <div class="sidebar-thumb">
                        @if (!string.IsNullOrEmpty(item.ImagePath))
                        {
                            <img src="@Url.Content(item.ImagePath)" alt="@item.Name" />
                        }
                        else
                        {
                            <span class="sidebar-thumb-icon">✦</span>
                        }
                    </div>
                    <div class="sidebar-item-info">
                        <p class="sidebar-item-name">@item.Name</p>
                        <p class="sidebar-item-style">@(item.Style?.Name ?? "—")</p>
                        <p class="sidebar-item-price">@item.Price ₴</p>
                    </div>
                </a>
            }
        </div>

        <div class="sidebar-footer">
            <a asp-controller="Catalog" asp-action="Index"
               style="display:block; text-align:center; font-size:0.7rem;
               letter-spacing:0.2em; text-transform:uppercase; color:#8062D6;
               text-decoration:none; transition:color 0.2s;"
               onmouseover="this.style.color='#F57799'"
               onmouseout="this.style.color='#8062D6'">
                View All →
            </a>
        </div>
    </div>

    <div class="home-content">
        <div style="width:400px; height:2px;
            background:linear-gradient(135deg,#8062D6,#E8A9A9);
            margin-bottom:1.5rem;"></div>

        <p style="font-size:0.6rem; letter-spacing:0.4em; color:#6b6b8a;
            text-transform:uppercase; margin-bottom:1rem;">
            Alternative Fashion Store
        </p>

        <h1 style="font-size:clamp(2.5rem,5vw,4.5rem); font-weight:900;
            line-height:1.05; margin-bottom:1.5rem; font-family:Georgia,serif;">
            <span style="color:#0C0950;">Dress to</span><br>
            <span style="background:linear-gradient(135deg,#8062D6,#121481);
                -webkit-background-clip:text; -webkit-text-fill-color:transparent;">
                Impress
            </span>
        </h1>

        <p style="color:#6b6b8a; font-size:0.95rem; line-height:1.9;
            max-width:480px; margin-bottom:2.5rem; font-family:Georgia,serif;">
            Visual Kei is the name of an artistic movement among Japanese music artists —
            an umbrella term for the styles worn by the bands and the fans emulating them.
        </p>

        <div style="display:flex; gap:1rem; flex-wrap:wrap;">
            <a asp-controller="Catalog" asp-action="Index"
               style="padding:0.85rem 2.5rem;
               background:linear-gradient(135deg,#8062D6,#E8A9A9);
               color:white; text-decoration:none; border-radius:4px;
               font-size:0.8rem; letter-spacing:0.15em; text-transform:uppercase;
               transition:opacity 0.2s;"
               onmouseover="this.style.opacity='0.85'"
               onmouseout="this.style.opacity='1'">
                Browse Catalogue →
            </a>
            <a asp-controller="Styles" asp-action="Index"
               style="padding:0.85rem 2rem; border:1px solid #8062D6;
               color:#8062D6; text-decoration:none; border-radius:4px;
               font-size:0.8rem; letter-spacing:0.15em; text-transform:uppercase;
               transition:all 0.2s;"
               onmouseover="this.style.background='#8062D6';this.style.color='white'"
               onmouseout="this.style.background='transparent';this.style.color='#8062D6'">
                Explore Styles
            </a>
        </div>
    </div>
</div>