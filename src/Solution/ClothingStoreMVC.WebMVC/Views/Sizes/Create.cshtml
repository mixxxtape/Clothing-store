@model ClothingStoreMVC.Domain.Entities.ProductAggregates.Size
@{
    ViewData["Title"] = "Add Size";
}

<h2 style="font-size:1.2rem; font-weight:900; letter-spacing:0.1em;
    text-transform:uppercase; margin-bottom:1.5rem; color:#0C0950;">
    Add Size
</h2>

<div style="max-width:400px;">
    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()
        <div style="background:#F9DFDF; border:1px solid #000; border-radius:8px; padding:1.5rem; margin-bottom:1rem;">
            <label asp-for="Name" style="font-size:0.75rem; letter-spacing:0.1em; text-transform:uppercase;
            color:#0C0950; display:block; margin-bottom:0.4rem;"></label>
            <input asp-for="Name" style="width:100%; padding:0.6rem 0.75rem; border-radius:6px;
            border:1px solid #2d2d40; background:#fff; color:#0C0950;
            font-size:0.9rem; box-sizing:border-box;" />
            <span asp-validation-for="Name" style="color:#F57799; font-size:0.75rem;"></span>
        </div>
        <button type="submit" style="padding:0.75rem 2rem; border:none;
            background:linear-gradient(135deg,#8062D6,#E8A9A9);
            color:white; border-radius:4px; font-size:0.8rem;
            letter-spacing:0.15em; text-transform:uppercase; cursor:pointer;">
            Create
        </button>
        <a asp-action="Index" style="margin-left:1rem; font-size:0.75rem; color:#6b6b8a;">Cancel</a>
    </form>
</div>