@model IEnumerable<ClothingStoreMVC.WebMVC.ViewModels.ProductListViewModel>

<table class="table">
    <thead>
        <tr>
            <th>Name</th>
            <th>Price</th>
            <th>Category</th>
            <th>Style</th>
            <th>Sizes</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Name</td>
                <td>@item.Price</td>
                <td>@item.CategoryName</td>
                <td>@item.StyleName</td>
                <td>@item.Sizes</td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id">Details</a>

                    @if (User.Identity.IsAuthenticated)
                    {
                        <a asp-controller="Products" asp-action="Details" asp-route-id="@item.Id"
                               style="font-size:0.75rem; color:#8062D6; text-decoration:none; margin-right:0.5rem;">
                            + Cart
                        </a>

                        <form asp-controller="Wishlists" asp-action="Toggle" method="post" style="display:inline;">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="productId" value="@item.Id" />
                            <input type="hidden" name="returnUrl" value="/Catalog" />
                            <button type="submit"
                                    style="background:transparent; border:none; color:#F57799;
                                font-size:0.85rem; cursor:pointer; padding:0; cursor:pointer;">
                                ♡
                            </button>
                        </form>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>